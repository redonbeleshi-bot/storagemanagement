# ============================================================
# KONFIGURIMI I SUPABASE
# ============================================================
# Ky është një skedar shembull. Kopjoje dhe ruaje si .env
# me të dhënat e tua reale.

# URL-ja e projektit Supabase
SUPABASE_URL=https://your-project-url.supabase.co

# Çelësi publik për lidhje (anon key)
# Gjeje te: Supabase Dashboard → Settings → API
SUPABASE_ANON_KEY=your-anon-key-here